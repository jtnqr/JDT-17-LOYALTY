# JDT-17-LOYALTY Environment Variables
# Copy this file to .env and fill in values before running Docker Compose
# chmod 600 .env

# ============================================================
# DATABASE
# ============================================================
POSTGRES_USER=loyalty
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=jdt17_loyalty
POSTGRES_PORT=5432

# ============================================================
# JWT
# ============================================================
# Generate with: openssl rand -hex 64
JWT_SECRET=changeme_generate_with_openssl_rand_hex_64
JWT_EXPIRY_HOURS=24

# ============================================================
# SPRING BOOT
# ============================================================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ============================================================
# PARTNER API KEYS (must match seed-data.sql or your DB)
# ============================================================
KFC_API_KEY=kfc_api_key_2026_secure_demo_only
MCD_API_KEY=mcd_api_key_2026_secure_demo_only

# ============================================================
# FRONTEND (Next.js)
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ============================================================
# SCHEDULER
# ============================================================
# Cron expression for point expiry job (default: daily at 1am)
# Format: second minute hour day month weekday
EXPIRY_CRON=0 0 1 * * *
